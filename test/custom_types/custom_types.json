{
  "openapi": "3.0.3",
  "info": {
    "title": "Custom Types API",
    "description": "Demonstrates generic types, custom named types, Nullable[T], time.Time, and json.RawMessage in OpenAPI spec generation.",
    "version": "1.0.0"
  },
  "paths": {
    "/events": {
      "get": {
        "tags": [
          "events"
        ],
        "summary": "list events",
        "description": "Returns events with time.Time (date-time string) and json.RawMessage (free-form JSON) fields.",
        "operationId": "listEvents",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "tags": [
          "items"
        ],
        "summary": "list items (paginated)",
        "description": "Returns a paginated list of items. The response wraps a generic Page[Item] type.",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageGithubComOaswrapGswagTestCustomTypesItem"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "items"
        ],
        "summary": "create item",
        "description": "Creates an item using custom named types: UserID (int64) and Status (string).",
        "operationId": "createItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Item"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/nullable": {
      "get": {
        "tags": [
          "nullable"
        ],
        "summary": "get nullable fields",
        "description": "Returns a struct with Nullable[T] fields mapped to nullable scalars via TypeMappings.",
        "operationId": "getNullable",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NullableFields"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "nullable"
        ],
        "summary": "post nullable fields",
        "operationId": "postNullable",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NullableFields"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NullableFields"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Event": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "metadata": {},
          "name": {
            "type": "string"
          },
          "occurred_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/components/schemas/UserID"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "NullableFields": {
        "type": "object",
        "properties": {
          "active": {
            "type": "boolean"
          },
          "age": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "score": {
            "type": "number"
          }
        }
      },
      "PageGithubComOaswrapGswagTestCustomTypesItem": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Item"
            },
            "nullable": true
          },
          "page": {
            "type": "integer"
          },
          "page_size": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          }
        }
      },
      "UserID": {
        "type": "integer",
        "format": "int64"
      }
    }
  }
}
{
  "openapi": "3.0.3",
  "info": {
    "title": "Examples API",
    "version": "1.0.0"
  },
  "paths": {
    "/items": {
      "get": {
        "tags": [
          "items"
        ],
        "summary": "List items",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ExamplesItem"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "name": "Widget",
                    "price": 10
                  },
                  {
                    "id": 2,
                    "name": "Gadget",
                    "price": 25
                  }
                ]
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "items"
        ],
        "summary": "Create item",
        "operationId": "createItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExamplesItem"
              },
              "example": "not json"
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExamplesItem"
                },
                "example": {
                  "id": 3,
                  "name": "Sprocket",
                  "price": 5
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  }
                },
                "example": {
                  "error": "invalid input"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ExamplesItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "integer"
          }
        }
      }
    }
  }
}